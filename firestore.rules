rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════
    // HELPERS
    // ═══════════════════════════════════════════════════════════

    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isSelf(userId) {
      return isAuth() && uid() == userId;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(uid())).data.role;
    }

    // Roles de usuario
    function isMinorista()    { return isAuth() && userRole() == 'cliente_minorista'; }
    function isDistribuidor() { return isAuth() && userRole() == 'cliente_distribuidor'; }
    function isVendedor()     { return isAuth() && userRole() == 'vendedor'; }
    function isAdmin()        { return isAuth() && userRole() == 'admin'; }

    // Agrupaciones
    function isCliente()  { return isMinorista() || isDistribuidor(); }
    function isInterno()  { return isVendedor()  || isAdmin(); }

    // ═══════════════════════════════════════════════════════════
    // users
    // ═══════════════════════════════════════════════════════════
    match /users/{userId} {
      allow read:   if isSelf(userId) || isInterno();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // customers  (perfil extendido de cliente, mismo UID)
    // ═══════════════════════════════════════════════════════════
    match /customers/{customerId} {
      // list sin auth permite el lookup por RNC en el login (antes de autenticar).
      allow list:   if true;
      allow get:    if isSelf(customerId) || isInterno();
      allow create: if isSelf(customerId);
      allow update: if isSelf(customerId) || isInterno();
      allow delete: if isAdmin();

      // Direcciones de entrega del cliente
      match /addresses/{addressId} {
        allow read:   if isSelf(customerId) || isInterno();
        allow create: if isSelf(customerId);
        allow update: if isSelf(customerId);
        allow delete: if isSelf(customerId);
      }
    }

    // ═══════════════════════════════════════════════════════════
    // catalog_categories
    // Público para lectura (catálogo visible incluso sin sesión).
    // Solo admin puede modificar.
    // ═══════════════════════════════════════════════════════════
    match /catalog_categories/{catId} {
      allow read:            if true;
      allow create, update:  if isAdmin();
      allow delete:          if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // products
    // Lectura pública. Escritura solo para internos (vendedor/admin).
    // ═══════════════════════════════════════════════════════════
    match /products/{productId} {
      allow read:            if true;
      allow create, update:  if isInterno();
      allow delete:          if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // orders
    // Cliente: crea y lee sus propios pedidos. Puede editar si status='pendiente'.
    // Vendedor: lee y actualiza todos los pedidos.
    // Admin: acceso total.
    // ═══════════════════════════════════════════════════════════
    match /orders/{orderId} {
      allow read: if isAuth() && (
        resource.data.customerId == uid() || isInterno()
      );
      allow create: if isAuth() &&
        request.resource.data.customerId == uid();
      allow update: if isInterno() || (
        isCliente() &&
        resource.data.customerId == uid() &&
        resource.data.status == 'pendiente'
      );
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════
    // invoices  (facturas generadas por ventas)
    // ═══════════════════════════════════════════════════════════
    match /invoices/{invoiceId} {
      allow read: if isAuth() && (
        resource.data.userId == uid() || isInterno()
      );
      allow create, update: if isInterno();
      allow delete:         if false;
    }

    // ═══════════════════════════════════════════════════════════
    // product_rules  (reglas mayoristas por producto)
    // ═══════════════════════════════════════════════════════════
    match /product_rules/{ruleId} {
      allow read:            if isAuth();
      allow create, update:  if isInterno();
      allow delete:          if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // app_config  (configuración global: banners, avisos, etc.)
    // ═══════════════════════════════════════════════════════════
    match /app_config/{docId} {
      allow read:   if true;
      allow write:  if isAdmin();
    }
  }
}

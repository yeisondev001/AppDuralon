rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isCliente() {
      return isSignedIn() && userRole() == 'cliente';
    }

    function isVendedor() {
      return isSignedIn() && userRole() == 'vendedor';
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    // vendedor y admin pueden operar internamente
    function isInterno() {
      return isSignedIn() && userRole() in ['vendedor', 'admin'];
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── users ─────────────────────────────────────────────────────────────────
    // Cada usuario solo puede leer y actualizar su propio documento.
    // Solo admin puede leer documentos de otros usuarios.
    match /users/{userId} {
      allow read:   if isSelf(userId) || isAdmin();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── customers ─────────────────────────────────────────────────────────────
    // Cliente: solo su propio documento.
    // Vendedor: puede leer todos (para gestionar pedidos/facturas).
    // Admin: acceso total.
    match /customers/{customerId} {
      allow read:   if isSelf(customerId) || isInterno();
      allow create: if isSelf(customerId);
      allow update: if isSelf(customerId) || isInterno();
      allow delete: if isAdmin();
    }

    // ── products ──────────────────────────────────────────────────────────────
    // Cualquiera puede ver productos (incluso invitados sin sesión).
    // Solo vendedor y admin pueden crear/editar/eliminar.
    match /products/{productId} {
      allow read:           if true;
      allow create, update: if isInterno();
      allow delete:         if isAdmin();
    }

    // ── orders ────────────────────────────────────────────────────────────────
    // Cliente: crear y leer sus propios pedidos.
    // Vendedor: leer todos los pedidos y actualizarlos (cambiar estado).
    // Admin: acceso total.
    match /orders/{orderId} {
      allow read:   if isSignedIn() && (
                      resource.data.customerId == request.auth.uid ||
                      isInterno()
                    );
      allow create: if isSignedIn();
      allow update: if isInterno();
      allow delete: if false;
    }

    // ── invoices ──────────────────────────────────────────────────────────────
    // Cliente: solo leer sus propias facturas.
    // Vendedor: crear y editar facturas.
    // Admin: acceso total.
    match /invoices/{invoiceId} {
      allow read:          if isSignedIn() && (
                             resource.data.customerId == request.auth.uid ||
                             isInterno()
                           );
      allow create, update: if isInterno();
      allow delete:        if false;
    }
  }
}
